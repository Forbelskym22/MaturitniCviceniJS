<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - NotesApp</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', -apple-system, sans-serif; }
        .apple-shadow { box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05); }
    </style>
</head>
<body class="bg-[#F5F5F7] min-h-screen flex items-center justify-center p-6 text-[#1D1D1F]">
    <div class="w-full max-w-[360px] space-y-8">
        <div class="text-center space-y-2">
            <div class="w-14 h-14 bg-black rounded-xl mx-auto flex items-center justify-center mb-5">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
            </div>
            <h1 class="text-2xl font-bold tracking-tight">Přihlaste se</h1>
            <p class="text-black/30 text-xs font-medium uppercase tracking-widest">Vítejte zpět</p>
        </div>

        <% if (locals.error) { %>
            <div class="bg-red-50 text-red-500 text-[10px] font-bold px-4 py-3 rounded-xl border border-red-100 text-center uppercase tracking-wider">
                <%= error %>
            </div>
        <% } %>

        <div class="bg-white p-7 rounded-2xl apple-shadow border border-black/5">
            <form action="/user/login" method="POST" class="space-y-4">
                <div class="space-y-1.5">
                    <label for="login" class="text-[10px] font-bold text-black/30 uppercase tracking-widest ml-1">Uživatel</label>
                    <input type="text" id="login" name="login" required 
                        class="w-full bg-[#F5F5F7] border-none rounded-xl px-4 py-2.5 text-sm focus:ring-1 focus:ring-black/10 outline-none transition-all placeholder:text-black/20"
                        placeholder="jméno">
                </div>
                
                <div class="space-y-1.5">
                    <label for="password" class="text-[10px] font-bold text-black/30 uppercase tracking-widest ml-1">Heslo</label>
                    <input type="password" id="password" name="password" required 
                        class="w-full bg-[#F5F5F7] border-none rounded-xl px-4 py-2.5 text-sm focus:ring-1 focus:ring-black/10 outline-none transition-all placeholder:text-black/20"
                        placeholder="••••••••">
                </div>

                <button type="submit" 
                    class="w-full bg-black text-white py-3 rounded-xl font-bold text-xs hover:opacity-90 active:scale-[0.98] transition-all shadow-lg shadow-black/10 mt-2">
                    PŘIHLÁSIT SE
                </button>
            </form>
        </div>

        <p class="text-center text-xs text-black/30 font-medium">
            Nemáte účet? <a href="/user/register" class="text-black font-bold hover:underline ml-1">Vytvořit účet</a>
        </p>
    </div>
</body>
</html>
