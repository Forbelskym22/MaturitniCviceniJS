<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', -apple-system, sans-serif; }
        .apple-blur { backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
        .apple-shadow { box-shadow: 0 4px 20px rgba(0,0,0,0.03); }
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="bg-[#F5F5F7] min-h-screen text-[#1D1D1F]">
    <!-- Navbar -->
    <nav class="bg-white/80 apple-blur border-b border-black/5 sticky top-0 z-40">
        <div class="max-w-3xl mx-auto px-6">
            <div class="flex justify-between h-14 items-center">
                <a href="/notes" class="flex items-center gap-2 text-black/40 hover:text-black transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
                    </svg>
                    <span class="text-xs font-bold uppercase tracking-widest">Zpět</span>
                </a>
                <span class="text-sm font-bold tracking-tight">Nastavení účtu</span>
                <div class="w-10"></div> <!-- Spacer -->
            </div>
        </div>
    </nav>

    <main class="max-w-2xl mx-auto py-12 px-6 space-y-8">
        <header>
            <h1 class="text-3xl font-bold tracking-tight">Profil</h1>
            <p class="text-black/30 text-xs font-medium uppercase tracking-widest mt-1">Správa vašeho digitálního já</p>
        </header>

        <% if (locals.error) { %>
            <div class="bg-red-50 text-red-500 text-[10px] font-bold px-4 py-3 rounded-xl border border-red-100 uppercase tracking-wider text-center">
                <%= error %>
            </div>
        <% } %>

        <% if (locals.success) { %>
            <div class="bg-green-50 text-green-600 text-[10px] font-bold px-4 py-3 rounded-xl border border-green-100 uppercase tracking-wider text-center">
                <%= success %>
            </div>
        <% } %>

        <!-- Update Form -->
        <section class="bg-white rounded-2xl p-8 apple-shadow border border-black/5">
            <form action="/user/settings/update" method="POST" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-black/30 uppercase tracking-widest ml-1">Nové jméno</label>
                        <input type="text" name="login" value="<%= user %>" 
                            class="w-full bg-[#F5F5F7] border-none rounded-xl px-4 py-3 text-sm focus:ring-1 focus:ring-black/10 outline-none transition-all font-medium">
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-black/30 uppercase tracking-widest ml-1">Nové heslo</label>
                        <input type="password" name="new_password" placeholder="Ponechte prázdné pro beze změny"
                            class="w-full bg-[#F5F5F7] border-none rounded-xl px-4 py-3 text-sm focus:ring-1 focus:ring-black/10 outline-none transition-all placeholder:text-black/20 font-medium">
                    </div>
                </div>

                <div class="pt-4 border-t border-black/[0.03]">
                    <div class="space-y-1.5 max-w-sm">
                        <label class="text-[10px] font-bold text-black/30 uppercase tracking-widest ml-1">Současné heslo</label>
                        <input type="password" name="current_password" required placeholder="Vyžadováno pro uložení změn"
                            class="w-full bg-[#F5F5F7] border-none rounded-xl px-4 py-3 text-sm focus:ring-1 focus:ring-black/10 outline-none transition-all placeholder:text-black/20 font-medium">
                    </div>
                </div>

                <button type="submit" class="bg-black text-white px-6 py-3 rounded-xl font-bold text-xs hover:opacity-90 transition-all active:scale-95 shadow-lg shadow-black/10">
                    ULOŽIT ZMĚNY
                </button>
            </form>
        </section>

        <!-- Danger Zone -->
        <section class="space-y-4">
            <h2 class="text-lg font-bold text-red-500">Nebezpečná zóna</h2>
            <div class="bg-red-50/50 rounded-2xl p-8 border border-red-100">
                <p class="text-sm text-red-900 font-medium mb-4">Smazáním účtu dojde k nevratnému odstranění všech vašich dat včetně všech poznámek.</p>
                
                <form action="/user/settings/delete" method="POST" class="flex flex-col md:flex-row gap-3">
                    <input type="password" name="confirm_password" required placeholder="Zadejte heslo pro smazání"
                        class="flex-1 bg-white border-red-200 border rounded-xl px-4 py-3 text-sm focus:ring-1 focus:ring-red-500 outline-none transition-all placeholder:text-red-200 font-medium text-red-900">
                    <button type="submit" onclick="return confirm('Opravdu chcete smazat svůj účet? Tato akce je nevratná!')"
                        class="bg-red-500 text-white px-6 py-3 rounded-xl font-bold text-xs hover:bg-red-600 transition-all active:scale-95 shadow-lg shadow-red-500/10">
                        SMAZAT ÚČET NAVŽDY
                    </button>
                </form>
            </div>
        </section>
    </main>
</body>
</html>
