<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', -apple-system, sans-serif; }
        .apple-blur { backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
        .apple-shadow { box-shadow: 0 4px 20px rgba(0,0,0,0.03); }
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="bg-[#F5F5F7] min-h-screen text-[#1D1D1F]" x-data="{ openModal: false }">
    <!-- Navbar -->
    <nav class="bg-white/80 apple-blur border-b border-black/5 sticky top-0 z-40">
        <div class="max-w-5xl mx-auto px-6">
            <div class="flex justify-between h-14 items-center">
                <div class="flex items-center gap-2">
                    <div class="bg-black p-1.5 rounded-lg">
                        <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                    </div>
                    <span class="text-md font-semibold tracking-tight">Poznámky</span>
                </div>

                <div x-data="{ open: false }" class="relative">
                    <button @click="open = !open" @click.outside="open = false" 
                        class="flex items-center gap-2 px-3 py-1 rounded-full hover:bg-black/5 transition-colors focus:outline-none">
                        <span class="text-xs font-medium opacity-80"><%= user %></span>
                        <div class="w-6 h-6 rounded-full bg-black/5 flex items-center justify-center text-[9px] font-bold text-black/40">
                            <%= user.charAt(0).toUpperCase() %>
                        </div>
                    </button>

                    <div x-show="open" x-cloak
                        x-transition:enter="transition ease-out duration-100"
                        x-transition:enter-start="opacity-0 scale-95"
                        x-transition:enter-end="opacity-100 scale-100"
                        class="absolute right-0 mt-2 w-36 bg-white/90 apple-blur rounded-xl shadow-xl border border-black/5 py-1.5 overflow-hidden origin-top-right">
                        <a href="/user/settings" class="block px-4 py-2 text-xs text-black/60 hover:bg-black/5 transition-colors font-medium">
                            Nastavení
                        </a>
                        <div class="h-px bg-black/[0.03] mx-2 my-1"></div>
                        <a href="/user/login" class="block px-4 py-2 text-xs text-red-500 hover:bg-black/5 transition-colors font-medium">
                            Odhlásit se
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto py-10 px-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-10">
            <div>
                <h1 class="text-3xl font-bold tracking-tight mb-1 text-black">Ahoj, <%= user %></h1>
                <p class="text-black/30 text-xs font-medium uppercase tracking-widest">
                    <% if (showFavoritesOnly) { %> 
                        Pouze důležité (<%= notes.length %>)
                    <% } else { %>
                        Všechny poznámky (<%= notes.length %>)
                    <% } %>
                </p>
            </div>

            <!-- Simple Filter Toggle (Segmented Control style) -->
            <div class="flex items-center gap-4">
                <div class="bg-black/5 p-1 rounded-xl flex">
                    <a href="/notes" 
                        class="px-4 py-1.5 rounded-lg text-xs font-semibold transition-all <%= !showFavoritesOnly ? 'bg-white shadow-sm text-black' : 'text-black/40 hover:text-black/60' %>">
                        Vše
                    </a>
                    <a href="/notes?favorites=true" 
                        class="px-4 py-1.5 rounded-lg text-xs font-semibold transition-all <%= showFavoritesOnly ? 'bg-white shadow-sm text-black' : 'text-black/40 hover:text-black/60' %>">
                        Důležité
                    </a>
                </div>

                <button @click="openModal = true" class="bg-black text-white px-4 py-2.5 rounded-xl font-semibold hover:bg-black/80 transition-all active:scale-95 text-xs shadow-lg shadow-black/10 flex items-center gap-2">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Nová
                </button>
            </div>
        </div>
        
        <!-- Notes Grid -->
        <% if (notes.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                <% notes.forEach(note => { %>
                    <div class="bg-white rounded-2xl p-5 border border-black/5 apple-shadow flex flex-col justify-between group relative overflow-hidden">
                        <% if (note.isFavorite) { %>
                            <div class="absolute top-0 right-0 w-12 h-12 bg-orange-400/5 rounded-bl-[24px] pointer-events-none"></div>
                        <% } %>
                        
                        <div>
                            <div class="flex justify-between items-start mb-2">
                                <h3 class="text-md font-bold leading-tight flex-1"><%= note.title %></h3>
                                <a href="/notes/favorite/<%= note._id %>?favorites=<%= showFavoritesOnly %>" class="ml-2 transition-transform active:scale-90">
                                    <% if (note.isFavorite) { %>
                                        <!-- Flag Icon (Important) -->
                                        <svg class="w-4 h-4 text-orange-500 fill-current" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10.107a.7.7 0 01.557 1.123L14.466 7l2.198 2.877a.7.7 0 01-.557 1.123H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd" />
                                        </svg>
                                    <% } else { %>
                                        <svg class="w-4 h-4 text-black/5 hover:text-black/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" />
                                        </svg>
                                    <% } %>
                                </a>
                            </div>
                            <p class="text-black/50 text-xs leading-relaxed line-clamp-4 font-medium"><%= note.content %></p>
                        </div>
                        <div class="mt-5 pt-3 border-t border-black/[0.03] flex justify-between items-center">
                            <span class="text-[9px] font-bold text-black/20 uppercase tracking-widest">
                                <%= new Date(note.createdAt).toLocaleDateString('cs-CZ') %>
                            </span>
                            <a href="/notes/delete/<%= note._id %>?favorites=<%= showFavoritesOnly %>" class="text-red-400 hover:text-red-500 transition-colors p-1.5 hover:bg-red-50 rounded-lg opacity-0 group-hover:opacity-100">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white rounded-2xl p-16 border border-black/5 apple-shadow flex flex-col items-center justify-center text-center">
                <div class="w-14 h-14 bg-[#F5F5F7] rounded-xl flex items-center justify-center mb-5">
                    <svg class="w-8 h-8 text-black/10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold mb-1">Žádné poznámky</h3>
                <p class="text-black/30 text-xs font-medium max-w-[240px] leading-relaxed">
                    <%= showFavoritesOnly ? 'Nemáte žádné důležité poznámky.' : 'Zatím jste nic nenapsali.' %>
                </p>
            </div>
        <% } %>
    </main>

    <!-- Modal for New Note -->
    <div x-show="openModal" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-6 bg-black/10 apple-blur" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">
        <div @click.outside="openModal = false" class="bg-white w-full max-w-md rounded-2xl apple-shadow p-7 border border-black/5 overflow-hidden" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 scale-95" x-transition:enter-end="opacity-100 translate-y-0 scale-100">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold">Nová poznámka</h2>
                <button @click="openModal = false" class="text-black/20 hover:text-black/40 transition-colors p-1 hover:bg-black/5 rounded-lg">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            
            <form action="/notes?favorites=<%= showFavoritesOnly %>" method="POST" class="space-y-5">
                <div class="space-y-1.5">
                    <label class="text-[10px] font-bold text-black/30 uppercase tracking-widest ml-1">Titulek</label>
                    <input type="text" name="title" required placeholder="Co máte v plánu?" 
                        class="w-full bg-[#F5F5F7] border-none rounded-xl px-4 py-3 text-sm focus:ring-1 focus:ring-black/10 outline-none transition-all placeholder:text-black/20 font-medium text-black">
                </div>
                
                <div class="space-y-1.5">
                    <label class="text-[10px] font-bold text-black/30 uppercase tracking-widest ml-1">Obsah</label>
                    <textarea name="content" required rows="4" placeholder="Sem napište své myšlenky..." 
                        class="w-full bg-[#F5F5F7] border-none rounded-xl px-4 py-3 text-sm focus:ring-1 focus:ring-black/10 outline-none transition-all placeholder:text-black/20 font-medium text-black resize-none"></textarea>
                </div>

                <div class="flex gap-3 pt-2">
                    <button type="button" @click="openModal = false" class="flex-1 px-4 py-3 rounded-xl font-bold text-xs bg-[#F5F5F7] text-black/60 hover:bg-black/5 transition-all active:scale-95">
                        Zrušit
                    </button>
                    <button type="submit" class="flex-[2] bg-black text-white px-4 py-3 rounded-xl font-bold text-xs hover:opacity-90 transition-all active:scale-95 shadow-lg shadow-black/10">
                        Uložit
                    </button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
